{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "web/frontend/dist" } },
    { "src": "api/index.py", "use": "@vercel/python", "config": { "includeFiles": "core/**" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
